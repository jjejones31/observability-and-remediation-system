# Devin API key — required for live session dispatch
# Get yours at: https://app.devin.ai/settings/api-keys
DEVIN_API_KEY=your-devin-api-key-here

# GitHub personal access token — used by `gh` CLI for issue management
# Needs: repo scope (read/write issues, PRs)
GH_TOKEN=ghp_your-github-token-here

# GitHub webhook secret — for verifying webhook payloads
# Set this to match the secret configured in your GitHub repo settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Target repository (owner/repo format)
GITHUB_REPO=jjejones31/superset
